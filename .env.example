# =============================================================================
# Switchboard Platform — environment variables
# Copy to `.env` and fill in. Phase 1 runs with ONLY the Phase-1 group set.
# All vendor accounts belong to the PLATFORM OPERATOR (you), configured once.
# Never collect vendor credentials from shop owners.
# =============================================================================

# ------------------------------- PHASE 1 -------------------------------------
# Database — local dev uses a sqlite file; production uses Turso (libSQL).
#   Local:  file:./dev.db           (resolves to prisma/dev.db)
#   Turso:  libsql://<db>.turso.io  (+ TURSO_AUTH_TOKEN below)
DATABASE_URL="file:./dev.db"
# TURSO_AUTH_TOKEN=                  # required only for a remote libsql:// url

# Auth — session signing secret. Generate: openssl rand -base64 32
AUTH_SECRET="change-me"

# App URL (no trailing slash). Dev: http://localhost:3000
APP_URL="http://localhost:3000"

# Admin allowlist (comma-separated emails). These users can reach /admin.
ADMIN_EMAILS="you@example.com"

# Anthropic — the wizard "brain" (config polish, website prefill, QA enrichment).
# Optional in dev: without a key the app uses a deterministic local fallback so
# the whole flow still works. Set it for real prefill + richer QA.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"        # config/prompt model
ANTHROPIC_QA_MODEL="claude-opus-4-8"     # stronger model for QA review

# Resend — magic-link + notification email. Without a key, emails (including
# the sign-in link) are logged to the server console so dev sign-in still works.
RESEND_API_KEY=""
RESEND_FROM="Switchboard <onboarding@resend.dev>"

# ------------------------------- PHASE 2 -------------------------------------
# (Not needed to run Phase 1.) Voice, telephony, billing, jobs, and n8n.

# Voice provider — Retell primary; Vapi optional behind the same interface.
RETELL_API_KEY=""
# VAPI_API_KEY=""

# Cal.com — booking calendar / event types.
CALCOM_API_KEY=""

# Twilio — phone numbers + A2P 10DLC registration (platform master account).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# TWILIO_A2P_POLICY_SID=""   # optional: TrustHub secondary-customer-profile policy SID
# Platform-shared Elastic SIP trunk (one-time setup) — routes inbound calls on
# provisioned numbers to Retell. Create a trunk with origination sip:sip.retellai.com,
# a credential list, and whitelist Retell SBC CIDR 18.98.16.120/30, then set:
TWILIO_SIP_TRUNK_SID=""
TWILIO_SIP_TERMINATION_URI=""   # e.g. your-trunk.pstn.twilio.com
TWILIO_SIP_USERNAME=""
TWILIO_SIP_PASSWORD=""

# Stripe — subscriptions (test mode first).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_CATCH=""
STRIPE_PRICE_FRONT_DESK=""
STRIPE_PRICE_GROWTH=""

# Upstash — QStash (background jobs) + Redis (rate limiting).
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# n8n — call broker + shop registry the self-hosted flows read.
N8N_BROKER_URL=""
N8N_REGISTRY_URL=""
N8N_REGISTRY_TOKEN=""

# ------------------------------- PHASE 3 -------------------------------------
# (Nothing new.)

# --------------------------- OBSERVABILITY -----------------------------------
# All optional. The in-app failure feed (/admin) works with none of these set;
# these just fan captured errors out to external tools.
# Sentry project DSN (Settings → Projects → Client Keys). Leave blank to disable.
SENTRY_DSN=""
# Any incoming webhook accepting a JSON {text} body (Slack-compatible) for
# real-time error alerts. Leave blank to disable.
ALERT_WEBHOOK_URL=""
# Hours a signup can sit with no progress before the onboarding-sweep cron pages
# admins about it (default 72). See "Scheduled jobs" in SETUP.md.
ONBOARDING_STUCK_HOURS="72"
# Days a canceled shop keeps its phone number before the reclaim cron releases it
# (default 30). Resubscribing within this window keeps the number.
CANCEL_GRACE_DAYS="30"
# Days without any calls before the health-check cron flags a live shop as a
# possible broken voice path (default 4). Only shops with prior call history.
SILENT_SHOP_DAYS="4"
# Days an owner can sit stalled mid-onboarding before the reminders cron sends a
# one-time nudge email (default 2).
ONBOARDING_NUDGE_DAYS="2"

# --------------------------- LANDING DEMO ------------------------------------
# Retell agent ids for the public landing-page "real call" demo (one shared,
# dynamic-variable-personalized agent per type). Provision with
# `node scripts/provision-demo-agents.mjs` and paste the ids here. Leave blank
# and the landing page falls back to the scripted preview only.
DEMO_AGENT_AUTO=""
DEMO_AGENT_AUTO_APPEARANCE=""
DEMO_AGENT_HVAC=""
