# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local sqlite (dev database)
*.db
*.db-journal
prisma/dev.db*

# vercel
.vercel

# n8n workflow exports carry baked-in live vendor secrets (Cal.com key, Twilio
# basic-auth) — never commit. See n8n/README before sharing any export.
/n8n/switchboard-cloud.json
/n8n/switchboard-core.json

# typescript
*.tsbuildinfo
next-env.d.ts
