{
  "expo": {
    "name": "Switchboard",
    "slug": "switchboard",
    "scheme": "switchboard",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.switchboard.owner",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.switchboard.owner",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-asset",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "ad014206-95d5-462c-a0df-a38ff893d979"
      }
    },
    "owner": "dlb8"
  }
}
