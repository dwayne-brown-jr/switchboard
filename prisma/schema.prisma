// Switchboard Platform — Prisma schema
// Provider is `sqlite` because Turso/libSQL is SQLite-compatible; the runtime
// connects through @prisma/adapter-libsql (see lib/db.ts) which works against
// both a local `file:` url (dev) and a remote `libsql://` Turso url (prod).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (better-auth managed tables). User carries our domain fields too.
// ---------------------------------------------------------------------------
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  emailVerified Boolean  @default(false)
  image         String?
  isAdmin       Boolean  @default(false) // also enforced via ADMIN_EMAILS env
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shops    Shop[]
  sessions Session[]
  accounts Account[]
  devices  DeviceToken[]
}

// ---------------------------------------------------------------------------
// Owner mobile app (Phase 0). Auth is a parallel, token-based path for native
// clients (better-auth's cookie sessions don't fit native): an email-OTP login
// (MobileAuthCode) exchanges for a long-lived, revocable device credential
// (DeviceToken). The bearer token sent by the app is an HMAC over the device id
// (lib/mobileAuth), so it can't be forged, and deleting the row revokes it.
// ---------------------------------------------------------------------------
model DeviceToken {
  id         String   @id @default(cuid()) // == the device id embedded in the bearer token
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushToken  String? // Expo push token (ExponentPushToken[...]) for notifications
  platform   String? // ios | android
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([pushToken])
}

model MobileAuthCode {
  id        String   @id @default(cuid())
  email     String
  codeHash  String // sha256 of the 6-digit code — never stored in the clear
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Domain
// ---------------------------------------------------------------------------
model Shop {
  id           String  @id @default(cuid()) // == client_id everywhere
  ownerId      String
  owner        User    @relation(fields: [ownerId], references: [id])
  businessName String
  vertical     String // auto | hvac | home_services
  city         String?
  timezone     String?
  websiteUrl   String?
  businessNumber String? // their existing published line
  ownerMobile  String? // alerts
  status       String  @default("onboarding") // onboarding | live | paused | canceled

  // billing
  stripeCustomerId String?
  stripeSubId      String?
  plan             String? // catch | front_desk | growth
  subStatus        String? // trialing | active | past_due | canceled

  // provisioned resources (non-secret IDs only)
  agentProvider  String? // retell | vapi
  agentId        String?
  agentNumber    String? // the AI's phone number
  twilioNumberSid String?
  calEventTypeMap Json? // LEGACY (pre-owned-scheduling Cal.com event-type map); unused — availability is now computed from config hours + own Booking rows
  a2pBrandSid    String?
  a2pCampaignSid String?
  a2pMessagingServiceSid String?
  a2pStatus      String? // not_started | submitted | approved | failed
  smsConsentAt   DateTime? // owner agreed to receive automated texts (A2P wall)
  smsOptOut      Boolean @default(false) // owner replied STOP to the agent number
  liveVersionId  String?
  ingestSecret   String? // per-shop secret for the call-ingest endpoint
  digestOptOut   Boolean @default(false) // owner unsubscribed from the weekly digest

  createdAt DateTime @default(now())

  versions AgentVersion[]
  run      OnboardingRun?
  calls    CallRecord[]
  bookings Booking[]
  auditLogs AuditLog[]
}

// Appointments we own. Switchboard computes availability from the shop's hours
// minus THIS shop's own bookings — so shops never collide on a shared calendar
// (the old single-Cal.com-user model let shop A's booking block shop B at the
// same clock-time). Each row is a fixed-length slot; times are stored as UTC
// instants (startUtc/endUtc) and rendered in the shop's timezone.
model Booking {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id])
  startUtc      DateTime
  endUtc        DateTime
  service       String?
  customerName  String?
  customerPhone String?
  status        String   @default("confirmed") // confirmed | canceled
  source        String   @default("agent") // agent | manual
  callId        String? // the call that created it, if any
  createdAt     DateTime @default(now())

  @@index([shopId, startUtc])
}

model AgentVersion {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id])
  config       Json // structured business config (no secrets)
  systemPrompt String
  qaVerdict    String? // go | no_go
  qaFlags      Json? // [{risk, fix}]
  status       String   @default("draft") // draft | approved | live | archived
  createdAt    DateTime @default(now())
}

model OnboardingRun {
  id          String   @id @default(cuid())
  shopId      String   @unique
  shop        Shop     @relation(fields: [shopId], references: [id])
  status      String   @default("in_progress") // in_progress | waiting_user | live | failed
  currentStep String?
  startedAt   DateTime @default(now())
  completedAt DateTime?
  steps       ProvisioningStep[]
}

model ProvisioningStep {
  id       String        @id @default(cuid())
  runId    String
  run      OnboardingRun @relation(fields: [runId], references: [id])
  key      String // see pipeline table
  type     String // auto | user
  status   String        @default("pending") // pending | running | done | waiting_user | failed | skipped
  result   Json? // external IDs, logs, error message, task payload
  attempts Int           @default(0)
  updatedAt DateTime     @updatedAt

  @@unique([runId, key])
}

model CallRecord {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id])
  callId        String   @unique
  timestamp     DateTime
  afterHours    Boolean  @default(false)
  durationSec   Int      @default(0)
  callerPhone   String?
  intent        String?
  outcome       String? // booked | message | escalated | missed_recovered | no_action
  booked        Boolean  @default(false)
  service       String?
  apptTime      String?
  estJobValue   Int      @default(0)
  hotJob        Boolean  @default(false)
  recovered     Boolean  @default(false)
  transcriptUrl String? // Retell recording_url (audio), not the transcript text
  summary       String? // short post-call summary from the voice provider
  transcript    String? // full transcript text
  handledAt     DateTime? // owner marked this call's follow-up as done (mobile app)
  flags         Json?
}

model WebhookEvent {
  id        String   @id // provider event id (stripe evt_..., etc.)
  provider  String
  createdAt DateTime @default(now())
}

// Captured errors / operational failures — the in-app observability feed.
// Written by lib/observability.reportError() from the onRequestError hook,
// provisioning failures, webhooks and jobs. Independent of Shop so shopless
// (infra) errors are still recorded.
model FailureEvent {
  id        String   @id @default(cuid())
  source    String // request | provisioning | webhook | job | manual
  level     String   @default("error") // error | warn
  message   String
  route     String? // request path or route file
  shopId    String? // optional correlation (no FK — errors outlive shops)
  digest    String? // Next error digest / dedupe hint
  detail    Json? // stack + context
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Audit log of owner-initiated changes (who/what/when) — Phase 3 hardening.
model AuditLog {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
  actorId   String? // user id, or null for system
  action    String // e.g. "wizard.completed", "version.published", "shop.paused"
  detail    Json?
  createdAt DateTime @default(now())
}
